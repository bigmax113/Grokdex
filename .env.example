PORT=3000
BASE_URL=http://localhost:3000

# Only this mailbox can receive login codes.
OTP_EMAIL=bigmax113@gmail.com

# Generate a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# xAI models for Continue CLI.
XAI_API_KEY=
GROK_CODING_MODEL=grok-build-0.1
GROK_GENERAL_MODEL=grok-4.3

# Gmail works with an app password, not the normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=bigmax113@gmail.com
SMTP_PASS=
SMTP_FROM="Continue Render Agent <bigmax113@gmail.com>"

# Optional: clone a repo into the remote workspace on startup.
WORKSPACE_REPO_URL=
WORKSPACE_BRANCH=main

# Remote document jobs. Use one long shared token on Render and on the local worker.
REMOTE_WORKER_TOKEN=
REMOTE_FILE_LIMIT_BYTES=26214400
REMOTE_TOTAL_LIMIT_BYTES=83886080

# Google Drive storage for uploads/results.
GOOGLE_DRIVE_FOLDER_ID=1WGbLfKoL8bYEi6fIXI2ktBPZmwAe86Pj

# Option A: OAuth donor files from OpenClaw. Put JSON text here or base64-encode it for Render.
GOOGLE_DRIVE_AUTH_MODE=oauth
GOOGLE_DRIVE_OAUTH_CLIENT_JSON=
GOOGLE_DRIVE_OAUTH_CLIENT_JSON_B64=
GOOGLE_DRIVE_OAUTH_TOKEN_JSON=
GOOGLE_DRIVE_OAUTH_TOKEN_JSON_B64=
GOOGLE_DRIVE_CONNECT_ENABLED=true
GOOGLE_DRIVE_USE_PERSONAL_PROFILES=true
OWNER_RESOURCE_FALLBACK_ENABLED=true
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=
GOOGLE_DRIVE_PROFILE_FOLDER_NAME=Continue Render Agent

# Option B: service account JSON, if you later share the Drive folder with that service account.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# Local worker only.
RENDER_AGENT_URL=https://your-render-service.onrender.com
REMOTE_WORKER_WORKSPACE=C:\Users\bigma\OneDrive\Документы\New project
REMOTE_WORKER_PROVIDER=qwen
REMOTE_WORKER_MODE=auto
